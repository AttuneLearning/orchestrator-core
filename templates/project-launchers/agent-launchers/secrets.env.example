# Copy to secrets.env and fill in. This file is sourced by the launchers
# (ensure_opensource_keys) so every tmux pane / non-login shell gets the
# open-source provider keys without depending on your shell rc.
#
#   cp secrets.env.example secrets.env
#   chmod 600 secrets.env
#   # then edit the values below
#
# secrets.env is gitignored — never commit real keys.

# DigitalOcean inference key (opencode orch_model provider, glm/deepseek/...).
MODEL_ACCESS_KEY=""

# Local qwen server key (the server ignores it, but opencode wants it set).
QWEN_LOCAL_API_KEY="blank"

# Note: the codex model menu needs NO key here — ./gather-models.sh reads
# codex's own OAuth-refreshed cache (~/.codex/models_cache.json).
