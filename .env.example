# ---------------------------------------------------------------------------
# Orchestrator environment configuration. Copy to .env and fill in.
# Environment variables override values in config/settings.yaml.
# ---------------------------------------------------------------------------

# Postgres canonical state. In-session Postgres example:
#   service postgresql start
#   sudo -u postgres createuser -s orchestrator
#   sudo -u postgres createdb orchestrator -O orchestrator
DATABASE_URL=postgresql://orchestrator@localhost:5432/orchestrator

# Reasoning agent (Anthropic). api.anthropic.com is reachable from the cloud env.
ANTHROPIC_API_KEY=
REASONING_MODEL=claude-opus-4-8

# Code-generation agent provider: stub | openai | anthropic
#   stub      - deterministic placeholder output, no network (default; verifiable in-cloud)
#   openai    - any OpenAI-compatible endpoint (set CODE_BASE_URL/CODE_MODEL/CODE_API_KEY)
#   anthropic - reuse the Anthropic SDK for code generation
# NOTE: the Qwen box 10.100.90.132:8081 is a private LAN IP, unreachable from the
# cloud env. Use a publicly reachable endpoint (added to Custom allowed domains)
# or run via a teleported local session.
CODE_PROVIDER=stub
CODE_BASE_URL=
CODE_MODEL=
CODE_API_KEY=

# Engine thresholds / caps
DRIFT_THRESHOLD=0.5
RETRY_CAP=3
STEP_BUDGET=25
MAX_DEPTH=3
MAX_SUBISSUES=8
MAX_ISSUES_PER_GOAL=30
