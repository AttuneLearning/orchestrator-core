# =============================================================================
# Orchestrator environment reference
# =============================================================================
# IMPORTANT: the app does NOT auto-load this file. Config is resolved from
# config/settings.yaml + config/instances.yaml, and any variable EXPORTED into
# the process environment overrides them. This file documents the variables you
# may want to export. Use it by copying to `.env` and `source`-ing it yourself,
# or set these in your shell / service manager. Everything here is OPTIONAL —
# each has a YAML or built-in default; the only thing you truly need is a
# reachable Postgres pointed at by your instance's database_url.
#
# Prefer per-instance config in config/instances.yaml over these globals; env
# vars are the escape hatch and win over YAML.
# =============================================================================

# --- Coordinator / database -------------------------------------------------
# ORCH_INSTANCE=myproject                 # same as passing --instance
# DATABASE_URL=postgresql://orchestrator:orchestrator@localhost:5432/myproject
# ROSTER_FILE=config/roster.myproject.yaml   # ignored when an instance selects its own roster

# --- Engine reasoner (decompose / gate / drift) -----------------------------
# REASONER=stub                           # stub | anthropic | openai | cli  (empty => anthropic-if-key-else-stub)
# REASONER_BASE_URL=https://your-endpoint/v1
# REASONER_MODEL=your-model
# REASONER_API_KEY=...
# REASONER_FALLBACK_MODEL=your-fallback-model
# ANTHROPIC_API_KEY=...                    # used when REASONER=anthropic (or empty + key present)
# REASONING_MODEL=claude-...               # anthropic model id

# --- Model-profile secret indirection ---------------------------------------
# Profiles in config/settings.yaml reference a key BY ENV-VAR NAME (api_key_env);
# set that variable here. The default DigitalOcean profile uses MODEL_ACCESS_KEY.
# MODEL_ACCESS_KEY=...

# --- Code agent (in-process code generation; usually 'stub' for pull mode) ---
# CODE_PROVIDER=stub                       # stub | openai | anthropic
# CODE_BASE_URL=https://your-endpoint/v1
# CODE_MODEL=your-model
# CODE_API_KEY=...

# --- Auto-promote (engine merges verified branches to your product repo) -----
# AUTO_PROMOTE_ENABLED=true
# PROMOTE_REPO_PATH=/abs/path/to/your/product-checkout
# PROMOTE_BRANCH=main

# --- Harness-owned verification (QA gate) ------------------------------------
# VERIFY_CMD=npm run typecheck && npm test
# (per-team verify_worktrees are set in config/instances.yaml, not here)

# --- Docs & misc -------------------------------------------------------------
# DOCS_PATH=/abs/path/to/your/docs
# CONTRACT_GATE_ENABLED=true
# DEFAULT_PIPELINE=pull-1
# ACCEPTANCE_DIR=/abs/path/to/workspace/.acceptance   # dashboard acceptance view

# --- Backups -----------------------------------------------------------------
# ORCH_DB_BACKUP_ENABLED=true
# ORCH_DB_BACKUP_DIR=backups

# --- Ops UIs (docker compose --profile ops) ----------------------------------
# DIRECTUS_ADMIN_EMAIL=admin@example.com
# DIRECTUS_ADMIN_PASSWORD=change-me-before-any-internet-facing-deploy
