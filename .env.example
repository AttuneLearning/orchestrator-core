# ---------------------------------------------------------------------------
# Orchestrator environment configuration. Copy to .env and fill in.
# Environment variables override values in config/settings.yaml.
# ---------------------------------------------------------------------------

# Postgres canonical state. In-session Postgres example:
#   service postgresql start
#   sudo -u postgres createuser -s orchestrator
#   sudo -u postgres createdb orchestrator -O orchestrator
DATABASE_URL=postgresql://orchestrator@localhost:5432/orchestrator

# Reasoning agent (Anthropic). api.anthropic.com is reachable from the cloud env.
ANTHROPIC_API_KEY=
REASONING_MODEL=claude-opus-4-8

# Code-generation agent provider: stub | openai | anthropic
#   stub      - deterministic placeholder output, no network (default; verifiable in-cloud)
#   openai    - any OpenAI-compatible endpoint (set CODE_BASE_URL/CODE_MODEL/CODE_API_KEY)
#   anthropic - reuse the Anthropic SDK for code generation
# NOTE: the Qwen box 10.100.90.132:8081 is a private LAN IP, unreachable from the
# cloud env. Use a publicly reachable endpoint (added to Custom allowed domains)
# or run via a teleported local session.
CODE_PROVIDER=stub
CODE_BASE_URL=
CODE_MODEL=
CODE_API_KEY=

# Engine thresholds / caps
DRIFT_THRESHOLD=0.5
RETRY_CAP=3
STEP_BUDGET=25
MAX_DEPTH=3
MAX_SUBISSUES=8
MAX_ISSUES_PER_GOAL=30

# Semantic memory / embedding provider (slice H).
#   stub   - deterministic, network-free bag-of-words embedder (default).
#            Works without pgvector; 256-dim unit vectors; no API key needed.
#   openai - OpenAI embeddings API (or any compatible endpoint).
#            Requires EMBED_API_KEY; EMBED_BASE_URL / EMBED_MODEL are optional.
#   none   - disable embeddings entirely (pure ILIKE search).
EMBED_PROVIDER=stub
EMBED_BASE_URL=
EMBED_MODEL=
EMBED_API_KEY=

# ---------------------------------------------------------------------------
# Ops UIs (Directus + Metabase) — only needed when running `--profile ops`
# ---------------------------------------------------------------------------

# Directus: must be at least 32 characters; change before any internet-facing deploy.
DIRECTUS_SECRET=changeme-directus-secret-32chars

# Directus admin account created on first startup.
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=Admin1234!

# Command template for runtime=cli agents (slice I). Placeholders: {prompt} {session_id}
# e.g. CLI_AGENT_CMD="claude -p {prompt} --resume {session_id}"
CLI_AGENT_CMD=

# Apply/verify leg (slice F) — OFF by default; artifacts stay stored-only.
# When enabled, qa_gate applies the artifact in a disposable git worktree of
# APPLY_REPO_PATH and runs VERIFY_CMD there. Promotion is human-only via
# `apply-promote` (local merge, never pushes).
APPLY_ENABLED=false
APPLY_REPO_PATH=
VERIFY_CMD=
